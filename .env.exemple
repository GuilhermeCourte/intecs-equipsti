# ---------- SQL Server ----------
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

# Instância nomeada (ex.: SQLEXPRESS). Deixe vazio se não usar.
DB_INSTANCE=

# Conexão TLS — para SQL Server local geralmente:
DB_ENCRYPT=
DB_TRUST_SERVER_CERT=

# ---------- Autenticação (JWT) ----------
JWT_SECRET=
JWT_EXPIRES_HOURS=

# ---------- Primeiro administrador (criado pelo "npm run init-db") ----------
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ---------- Servidor ----------
PORT=3000
